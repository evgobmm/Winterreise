  "title_de": "Rast",
  "title_ru": "Привал",
  "stanzas": [
    {
      "lines_de": [
        "Nun merk' ich erst, wie müd' ich bin,",
        "Da ich zur Ruh' mich lege;",
        "Das Wandern hielt mich munter hin",
        "Auf unwirtbarem Wege."
      ],
      "lines_ru": [
        {
          "segments": [
            { "ru": "Теперь", "de": "Nun" },
            { "ru": "лишь", "de": "erst" },
            { "ru": "замечаю", "de": "merk'" },
            { "ru": "я,", "de": "ich" },
            { "ru": "как", "de": "wie" },
            { "ru": "устал", "de": "müd'... bin" },
            { "ru": "я,", "de": "ich" }
          ],
          "annotations": []
        },
        {
          "segments": [
            { "ru": "Когда", "de": "Da" },

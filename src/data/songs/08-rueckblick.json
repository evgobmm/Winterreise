  "stanzas": [
    {
      "lines_de": [
        "Es brennt mir unter beiden Sohlen,",
        "Tret' ich auch schon auf Eis und Schnee.",
        "Ich möcht' nicht wieder Atem holen,",
        "Bis ich nicht mehr die Türme seh'."

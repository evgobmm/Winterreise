      "lines_de": [
        "In die tiefsten Felsengründe",
        "Lockte mich ein Irrlicht hin.",
        "Wie ich einen Ausgang finde,",
        "Liegt nicht schwer mir in dem Sinn."
      ],
      "lines_ru": [

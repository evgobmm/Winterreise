  "stanzas": [
    {
      "lines_de": [
        "Manche Trän' aus meinen Augen",
        "Ist gefallen in den Schnee;",
        "Seine kalten Flocken saugen",
        "Durstig ein das heiße Weh."
      ],
      "lines_ru": [
        {
          "segments": [
            { "ru": "Не одна", "de": "Manche" },

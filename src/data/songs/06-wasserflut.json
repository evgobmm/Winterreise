      "lines_ru": [
        {
          "segments": [
            { "ru": "Снег,", "de": "Schnee" },
            { "ru": "ты", "de": "du" },
            { "ru": "знаешь", "de": "weißt" },
            { "ru": "о", "de": "von" },
            { "ru": "моей", "de": "meinem" },
            { "ru": "тоске:", "de": "Sehnen" }

  "stanzas": [
    {
      "lines_de": [
        "Fremd bin ich eingezogen,",
        "Fremd zieh' ich wieder aus.",
        "Der Mai war mir gewogen",
        "Mit manchem Blumenstrauß.",
        "Das Mädchen sprach von Liebe,",
        "Die Mutter gar von Eh' —",
        "Nun ist die Welt so trübe,",
        "Der Weg gehüllt in Schnee."

          "annotations": [
            {
              "type": "lang",
              "segment_range": [1, 1],
              "text": "Это то самое слово manches, которое встречалось во многих песнях цикла и которое мы обычно переводили как «не один». Но здесь другая ситуация и мы имеем возможность дать точный, естественный перевод."
            }
          ]
        },
        {
          "segments": [
            { "ru": "Знай,", "de": "Tun" },
            { "ru": "себя", "de": "sich" },

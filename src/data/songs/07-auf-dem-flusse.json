{
  "number": 7,
  "title_de": "Auf dem Flusse",
  "title_ru": "На речке",
  "stanzas": [
    {
      "lines_de": [
        "Der du so lustig rauschtest,",
        "Du heller, wilder Fluss,",
        "Wie still bist du geworden,",
        "Gibst keinen Scheidegruß."
